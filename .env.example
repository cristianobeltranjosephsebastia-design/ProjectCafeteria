# --- FIREBASE CONFIGURATION ---
FIREBASE_KEYS_PATH=serviceAccountKey.json 
# API Key para autenticación web/cliente
FIREBASE_WEB_API_KEYS=tu_web_api_key_aqui

# --- CLOUDINARY CONFIGURATION ---
# Se obtienen desde el Dashboard de Cloudinary
CLOUDINARY_CLOUD_NAME=nombre_de_tu_cloud
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- AI CONFIGURATION ---
# Google Gemini API Key
GEMINI_API_KEY=tu_gemini_api_key_aqui